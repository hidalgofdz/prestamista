# Copy to .env and adjust as needed. .env is gitignored; .env.example is not.
# These values are read by config/database.yml (via dotenv-rails) and by
# compose.yml when starting the local Postgres container.

POSTGRES_USER=prestamista
POSTGRES_PASSWORD=prestamista_dev
POSTGRES_DB=prestamista_development
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
