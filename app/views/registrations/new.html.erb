<h1><%= t(".title") %></h1>

<% if flash[:alert] %>
  <p><%= flash[:alert] %></p>
<% end %>

<%= form_with url: registration_path, scope: :registration do |f| %>
  <div class="field">
    <%= f.label :name, class: "field__label" %>
    <div class="field__control">
      <%= f.text_field :name, autofocus: true, class: "field__input" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :email, class: "field__label" %>
    <div class="field__control">
      <%= f.email_field :email, class: "field__input" %>
    </div>
  </div>

  <div>
    <%= f.submit t(".submit"), class: "btn btn--primary" %>
  </div>
<% end %>

<p><%= link_to t(".sign_in"), new_session_path, class: "btn btn--link" %></p>
