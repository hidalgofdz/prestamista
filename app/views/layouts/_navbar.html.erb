<nav class="navbar">
  <div class="navbar__start">
    <%= link_to t("application.name"), root_path, class: "navbar__brand" %>
    <%= link_to t("nav.loans"), loans_path, class: "navbar__link #{"active" if controller_name == "loans"}" %>
    <%= link_to t("nav.borrowers"), borrowers_path, class: "navbar__link #{"active" if controller_name == "borrowers"}" %>
  </div>

  <div class="navbar__end">
    <span class="navbar__user"><%= Current.user.name %></span>
    <%= button_to t("nav.log_out"), session_path, method: :delete, class: "navbar__link" %>
  </div>
</nav>
