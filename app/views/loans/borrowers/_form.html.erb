<div class="inline-form">
  <%= form_with model: borrower, url: loans_borrowers_path do |f| %>
    <% if borrower.errors.any? %>
      <div id="errors">
        <ul>
          <% borrower.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="inline-form__fields">
      <div class="field">
        <%= f.label :name, class: "field__label" %>
        <div class="field__control">
          <%= f.text_field :name, autofocus: true, class: "field__input" %>
        </div>
      </div>

      <div class="field">
        <%= f.label :phone, class: "field__label" %>
        <div class="field__control">
          <%= f.telephone_field :phone, class: "field__input" %>
        </div>
      </div>
    </div>

    <div class="inline-form__actions">
      <%= f.submit t(".submit"), class: "btn btn--primary btn--sm" %>
      <%= link_to t(".cancel"), "#", class: "btn btn--ghost btn--sm", data: { action: "click->inline-form#close" } %>
    </div>
  <% end %>
</div>
