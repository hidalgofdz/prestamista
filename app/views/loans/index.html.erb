<div class="table-wrap" data-controller="table-filter">
  <div class="table-toolbar">
    <h1 class="table-toolbar__title">
      <%= t(".title") %>
      <span class="table-toolbar__count"><%= @active_loans.size + @paid_off_loans.size %></span>
    </h1>
    <div class="table-toolbar__actions">
      <%= link_to t(".new"), new_loan_path, class: "btn btn--primary" %>
    </div>
  </div>

  <% if @active_loans.any? || @paid_off_loans.any? %>
    <% if @active_loans.any? && @paid_off_loans.any? %>
      <nav class="table-filters" aria-label="<%= t(".title") %>">
        <span class="table-filters__label"><%= t(".col_status") %></span>
        <button class="filter-chip" aria-pressed="false" data-filter="active" data-table-filter-target="chip" data-action="table-filter#filter">
          <%= t(".status_active") %>
          <span class="filter-chip__count"><%= @active_loans.size %></span>
        </button>
        <button class="filter-chip" aria-pressed="false" data-filter="paid_off" data-table-filter-target="chip" data-action="table-filter#filter">
          <%= t(".status_paid_off") %>
          <span class="filter-chip__count"><%= @paid_off_loans.size %></span>
        </button>
      </nav>
    <% end %>

    <ul class="loan-cards">
      <% @active_loans.each do |loan| %>
        <li data-table-filter-target="row" data-filter-group="active">
          <%= render "loan_card", loan: loan, next_payment: loan.next_payment_date, overdue: loan.overdue?, paid_off: false %>
        </li>
      <% end %>
      <% @paid_off_loans.each do |loan| %>
        <li data-table-filter-target="row" data-filter-group="paid_off">
          <%= render "loan_card", loan: loan, next_payment: nil, overdue: false, paid_off: true %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="table-state">
      <svg class="table-state__icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
        <path d="M9 12h6M12 9v6"/>
      </svg>
      <p class="table-state__title"><%= t(".empty") %></p>
      <p class="table-state__body"><%= t(".empty_body") %></p>
      <div class="table-state__actions">
        <%= link_to t(".new"), new_loan_path, class: "btn btn--primary" %>
      </div>
    </div>
  <% end %>
</div>
