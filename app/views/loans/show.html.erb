<h1><%= @loan.borrower.name %></h1>

<dl>
  <dt><%= t(".amount") %></dt>
  <dd><p><%= currency(@loan.amount) %></p></dd>

  <dt><%= t(".annual_interest_rate") %></dt>
  <dd><p><%= number_to_percentage(@loan.annual_interest_rate, precision: 2) %></p></dd>

  <dt><%= t(".term_months") %></dt>
  <dd><p><%= @loan.term_months %></p></dd>

  <dt><%= t(".monthly_payment") %></dt>
  <dd><p><%= currency(@loan.monthly_payment) %></p></dd>

  <dt><%= t(".start_date") %></dt>
  <dd><p><%= l(@loan.start_date) %></p></dd>

  <dt><%= t(".end_date") %></dt>
  <dd><p><%= l(@loan.end_date) %></p></dd>

  <dt><%= t(".remaining_balance") %></dt>
  <dd><p><%= currency(@loan.remaining_balance) %></p></dd>
</dl>

<% if @loan.paid_off? %>
  <p class="paid-off"><%= t(".paid_off") %></p>
<% end %>

<h2><%= t(".record_payment") %></h2>
<%= form_with model: @payment, url: loan_payments_path(@loan), multipart: true do |f| %>
  <% if @payment.errors.any? %>
    <div id="errors">
      <ul>
        <% @payment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="field">
    <%= f.label :amount, class: "field__label" %>
    <div class="field__control">
      <%= f.number_field :amount, step: "0.01", class: "field__input" %>
    </div>
  </div>
  <div class="field">
    <%= f.label :date, class: "field__label" %>
    <div class="field__control">
      <%= f.date_field :date, class: "field__input" %>
    </div>
  </div>
  <div class="field">
    <%= f.label :proof, t(".proof_label"), class: "field__label" %>
    <div class="field__control">
      <%= f.file_field :proof, accept: "image/jpeg,image/png,image/webp,image/heic,application/pdf", class: "field__input" %>
    </div>
  </div>
  <div>
    <%= f.submit t(".submit_payment"), class: "btn btn--primary" %>
  </div>
<% end %>

<% if @payments.any? %>
  <div class="table-wrap">
    <div class="table-toolbar">
      <h2 class="table-toolbar__title"><%= t(".payment_history") %></h2>
    </div>
    <ul id="payments" class="payment-list">
      <% @payments.each do |payment| %>
        <li class="payment-list__item">
          <div class="payment-list__row">
            <time class="payment-list__date" datetime="<%= payment.date.iso8601 %>"><%= l(payment.date) %></time>
            <span class="payment-list__amount">
              <span class="visually-hidden"><%= t(".payment_amount_label") %></span>
              <%= currency(payment.amount) %>
            </span>
            <% if payment.proof.attached? %>
              <% if payment.proof.content_type == "application/pdf" %>
                <%= link_to rails_blob_path(payment.proof, disposition: :attachment), class: "payment-list__proof", aria: { label: t(".payment_proof_label", amount: currency(payment.amount), date: l(payment.date)) } do %>
                  <span class="payment-list__proof-pdf"><%= t(".payment_pdf_label") %></span>
                <% end %>
              <% else %>
                <%= link_to rails_blob_path(payment.proof, disposition: :inline), class: "payment-list__proof", aria: { label: t(".payment_proof_label", amount: currency(payment.amount), date: l(payment.date)) } do %>
                  <%= image_tag payment.proof.variant(resize_to_limit: [64, 64]), class: "payment-list__proof-thumb", alt: "" %>
                <% end %>
              <% end %>
            <% end %>
          </div>
          <p class="payment-list__split">
            <%= t(".payment_principal") %>: <%= currency(payment.principal_applied) %> · <%= t(".payment_interest") %>: <%= currency(payment.interest_applied) %>
          </p>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= link_to t(".edit"), edit_loan_path(@loan), class: "btn btn--secondary" %>
<%= link_to t(".back"), loans_path, class: "btn btn--ghost" %>
